# Slack app credentials (create the app from manifest.json, then find these in app settings)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# LLM (OpenRouter, OpenAI-compatible endpoint, Claude models)
LLM_API_KEY=sk-or-...
LLM_MODEL=anthropic/claude-sonnet-5

# Optional: a channel ID the bot is a member of, used by scripts/spike.js and scripts/seed.js
SPIKE_CHANNEL_ID=
