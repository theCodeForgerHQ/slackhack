# Copy this file to ".env" and fill in your keys.
# Do NOT commit .env or paste tokens into chat.

# --- Slack (required) ---
# "Bot User OAuth Token" — OAuth & Permissions page (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-REPLACE_ME

# "App-Level Token" with connections:write — Basic Information page (starts with xapp-)
SLACK_APP_TOKEN=xapp-REPLACE_ME

# "Signing Secret" — Basic Information page
SLACK_SIGNING_SECRET=REPLACE_ME

# "User OAuth Token" — needed for Real-Time Search API and Slack MCP server (starts with xoxp-)
SLACK_USER_TOKEN=xoxp-REPLACE_ME

# --- Evidence (required) ---
# Tavily API key — https://tavily.com (web + news search)
TAVILY_API_KEY=tvly-REPLACE_ME

# Google Fact Check Tools API (free) — https://console.cloud.google.com → enable "Fact Check Tools API"
GOOGLE_FACTCHECK_API_KEY=REPLACE_ME

# --- Model providers (at least one required) ---
# NVIDIA NIM — free tier, powers the default panel — https://integrate.api.nvidia.com
NVIDIA_API_KEY=REPLACE_ME

# Optional frontier / faster providers:
OPENROUTER_API_KEY=REPLACE_ME   # openrouter.ai — GPT-5.5, Claude Opus 4.8, Gemini 3.5
CEREBRAS_API_KEY=REPLACE_ME     # cerebras.ai — very fast inference
GROQ_API_KEY=REPLACE_ME         # groq.com — fast Llama
GEMINI_API_KEY=REPLACE_ME       # Google Gemini direct

# --- Cloud knowledge graph (optional, free tier) ---
# Neo4j AuraDB — https://console.neo4j.io (free: 200K nodes / 400K relationships)
NEO4J_URI=neo4j+s://REPLACE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_ME

# --- Multimodal (optional) ---
# Deepgram — voice/audio fact-checking — https://deepgram.com
DEEPGRAM_API_KEY=REPLACE_ME

# --- Arbiter judgment tuning (optional) ---
# ARBITER_NAME=Arbiter                      # display name used in bot messages
# ARBITER_SUBSTANCE_MIN_WORDS=120           # min words before substance mode can trigger
# ARBITER_CLAIM_MIN_CHARS=15                # min chars before proactive judgment runs

# --- Model routing (optional overrides) ---
# VERDICT_ROUTER=cerebras:llama-3.3-70b        # fast triage model
# VERDICT_DEBATERS=nvidia:meta/llama-4-maverick-17b-128e-instruct,nvidia:qwen/qwen3.5-122b-a10b,nvidia:google/gemma-3-27b-it
# VERDICT_SYNTH=nvidia:meta/llama-4-maverick-17b-128e-instruct
# VERDICT_VISION=nvidia:nvidia/nemotron-nano-12b-v2-vl

# Frontier demo panel (direct keys — three labs argue every claim):
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# VERDICT_DEBATERS=openai:gpt-4.1,anthropic:claude-sonnet-5,gemini:gemini-2.5-flash
# VERDICT_SYNTH=anthropic:claude-sonnet-5
# Or via OpenRouter with one key:
# VERDICT_DEBATERS=openrouter:openai/gpt-5.5,openrouter:anthropic/claude-opus-4.8,openrouter:google/gemini-3.5-flash
