{
  "display_information": {
    "name": "Arbiter",
    "description": "The workspace's judgment layer: fact-checks claims, weighs the substance of long content (anti-workslop receipts), and brings the missing voices into forming decisions — one multi-agent brain over your workspace's own record, with a full self-audit trail.",
    "background_color": "#1a1a2e"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "assistant_view": {
      "assistant_description": "Send a claim to fact-check, paste a long update to weigh its substance, or describe a decision — I'll find the missing voices, check the record, and argue the counter-case.",
      "suggested_prompts": []
    },
    "bot_user": {
      "display_name": "Arbiter",
      "always_online": true
    },
    "shortcuts": [
      {
        "name": "Judge this message",
        "type": "message",
        "callback_id": "judge_message",
        "description": "Arbiter picks the right judgment: fact-check, substance receipt, or missing voices"
      }
    ],
    "slash_commands": [
      {
        "command": "/verdict",
        "description": "Fact-check a claim with a multi-agent debate",
        "usage_hint": "[claim to verify]",
        "should_escape": false
      },
      {
        "command": "/arbiter",
        "description": "Judge a claim, or use: substance <text> · voices <decision>",
        "usage_hint": "[claim | substance <text> | voices <decision>]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:join",
        "channels:read",
        "chat:write",
        "commands",
        "files:read",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "lists:read",
        "lists:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "reactions:read",
        "reactions:write",
        "users:read"
      ],
      "user": [
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "users:read",
        "users:read.email",
        "reactions:read",
        "reactions:write",
        "canvases:read",
        "canvases:write",
        "files:read",
        "emoji:read"
      ],
      "user_optional": [
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "canvases:read",
        "canvases:write"
      ]
    },
    "pkce_enabled": false
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "assistant_thread_started",
        "assistant_thread_context_changed",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "reaction_added"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false,
    "is_mcp_enabled": true
  }
}
