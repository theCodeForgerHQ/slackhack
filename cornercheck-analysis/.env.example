# CornerCheck environment template. Copy to .env and fill in real values.
# Real values NEVER get committed; .env is gitignored.

# Slack app (from api.slack.com/apps after installing slack/manifest.json)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Anthropic (Claude Agent SDK brain)
ANTHROPIC_API_KEY=sk-ant-your-key

# Model pins (no hardcoded model strings anywhere in code)
CORNERCHECK_MODEL=claude-opus-4-8
CORNERCHECK_MODEL_FALLBACK=claude-sonnet-4-6

# Postgres (docker compose maps host 5433 -> container 5432 to dodge system Postgres)
DATABASE_URL=postgresql://cornercheck:cornercheck@localhost:5433/cornercheck

# Audit ledger HMAC key (generate: python -c "import secrets; print(secrets.token_hex(32))")
CORNERCHECK_LEDGER_HMAC_KEY=replace-with-64-hex-chars

# Optional: boxing-data.com RapidAPI key (live record corroboration of boxing verdicts).
# Without it, corroboration reads UNAVAILABLE and verdicts stand on commission data; the
# recorded-real fixture fallback serves only when CORNERCHECK_DEMO_FALLBACK=true.
BOXING_DATA_API_KEY=

# Optional: incoming webhook for the #cornercheck-ops daily roster-monitor digest.
# Unset, the monitor still runs and ledgers its findings; it just cannot push.
OPS_WEBHOOK_URL=

# Demo: serve deterministic cached real-data fallbacks when true
CORNERCHECK_DEMO_FALLBACK=false
