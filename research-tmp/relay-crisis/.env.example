# --- Slack (dev app from manifest.dev.yaml — Socket Mode) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# App-level token with connections:write — presence of this switches the app to Socket Mode
SLACK_APP_TOKEN=xapp-...

# --- LLM (provider is swappable; default openai) ---
# LLM_PROVIDER=openai (default) uses OPENAI_API_KEY; =anthropic uses ANTHROPIC_API_KEY.
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Only needed if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Optional per-tier model overrides (defaults: openai gpt-4o / gpt-4o-mini).
# LLM_MODEL_QUALITY=
# LLM_MODEL_CHEAP=
# Dedupe embeddings reuse OPENAI_API_KEY (text-embedding-3-small); absent -> pg_trgm fallback.

# --- Infra (docker compose up -d) ---
DATABASE_URL=postgres://relay:relay@localhost:5433/relay
REDIS_URL=redis://localhost:6379

# --- App ---
PORT=3000
LOG_LEVEL=debug
# AES-256-GCM key for contact_vault, 64 hex chars. Generate: openssl rand -hex 32
CONTACT_VAULT_KEY=
# Demo SLA compression (1 = real time; 0.02 = 45min -> ~54s). Labeled in #judges-start-here.
SLA_MULTIPLIER=1
