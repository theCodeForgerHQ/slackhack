# Lore — Slack configuration. Copy to .env and fill in your values.

# Required for Socket Mode (no public URL needed)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret

# Local model for research (Ollama, OpenAI-compatible). Without this, Lore falls back to a
# deterministic offline stub (loud warning in live mode) — set it to research with a real model.
OLLAMA_API_BASE=http://localhost:11434/v1
LORE_MODEL=llama3.2

# Consult the org-glossary MCP server (servers/glossary_server.py) to resolve domain
# terms/acronyms during research, feeding the definitions back into retrieval. On by default.
LORE_MCP_GLOSSARY=1

# Retrieval backend for the search seam:
#  * default (bot token)      — SlackHistoryRTS over conversations.history + a local ranker.
#  * official Slack Search API — set LORE_USE_RTS_API=1 AND provide a USER token (xoxp-…) with
#    the search:read scope; Lore then calls search.messages directly. Bot tokens can't (Slack
#    platform rule), so this is opt-in.
# LORE_USE_RTS_API=1
# SLACK_USER_TOKEN=xoxp-your-user-token-with-search-read

# Stream the live research trace on /lore, @mention and DM surfaces (not just the Assistant).
# On by default so the money-shot is visible however a judge invokes Lore. Set 0 for a quieter,
# answer-only reply.
# LORE_STREAM_TRACE=1

# Channels to index. Leave unset to auto-index every channel Lore is a member of
# (needs channels:read). Or pin them explicitly: "C0123:pricing,C0456:leadership".
# LORE_CHANNELS=

# Logging
# LORE_LOG_LEVEL=INFO
