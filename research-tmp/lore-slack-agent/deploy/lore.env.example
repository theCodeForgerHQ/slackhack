# Lore runtime environment. Copy to a PROTECTED location OUTSIDE the repo
# (e.g. ~/projects/slack-mcp-agent/lore.env) and `chmod 600` it. NEVER commit real tokens.

# Slack app credentials (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Local model (Ollama, OpenAI-compatible) — private, no cloud.
# Prefer a NON-thinking model for snappy live responses (a "thinking" model spends its token
# budget on hidden reasoning and can stall). gemma3:27b answers a cited query in ~15s.
OLLAMA_API_BASE=http://localhost:11434/v1
LORE_MODEL=gemma3:27b
LORE_MAX_TOKENS=700

# Channels to index ("C123:name,..."), or leave unset to auto-index channels the bot is in
LORE_CHANNELS=C0000000000:pricing,C1111111111:leadership

# Consult the org-glossary MCP server during research
LORE_MCP_GLOSSARY=1

LORE_LOG_LEVEL=INFO
LORE_LLM_TIMEOUT=180

# --- Usage notifications (optional): tell the operator when Lore is queried (it uses local GPU) ---
# Slack DM (works with the bot token; set to the operator's Slack user id):
LORE_NOTIFY_SLACK_USER=U000000000
LORE_NOTIFY_MIN_INTERVAL=6
# Email (needs a Gmail App Password — Google Account → Security → App passwords → Mail):
# LORE_NOTIFY_TO=you@example.com
# LORE_SMTP_USER=you@gmail.com
# LORE_SMTP_PASSWORD=your-16-char-app-password
# LORE_SMTP_HOST=smtp.gmail.com
# LORE_SMTP_PORT=587
