# --- LLM (provider-agnostic) ---
# Provider precedence: OPENAI_API_KEY -> OpenAI; else ANTHROPIC_API_KEY -> Anthropic;
# else the deterministic mock/heuristic (offline demo + hermetic tests).
# KEPT_LLM_PROVIDER can hard-override selection: openai | anthropic | mock.
KEPT_LLM_PROVIDER=

# Anthropic Claude (structured output via forced tool use):
ANTHROPIC_API_KEY=
KEPT_LLM_MODEL=claude-opus-4-8

# OpenAI (structured output via Structured Outputs; set OPENAI_API_KEY to use it):
OPENAI_API_KEY=
# Any OpenAI model that supports Structured Outputs; defaults to gpt-4o:
OPENAI_MODEL=gpt-4o

# --- Event store (Postgres) ---
DATABASE_URL=postgres://kept:kept@localhost:5432/kept

# --- Reminder / retry queue (Redis + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Slack (hybrid substrate: real Slack surface) ---
# Two boot modes (auto-selected):
#  1. Single-token / Socket Mode (local dev, demo): set SLACK_BOT_TOKEN (+ optional
#     SLACK_APP_TOKEN for Socket Mode). Leave the OAuth trio below EMPTY.
#  2. OAuth HTTP mode (W2, multi-workspace, the Marketplace/AWS deploy): set
#     SLACK_CLIENT_ID + SLACK_CLIENT_SECRET + SLACK_STATE_SECRET. No bot token needed;
#     each workspace's token is stored in the InstallationStore at install time.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Slack OAuth (W2 HTTP mode; all three enable OAuth HTTP mode) ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Any long random string — signs the OAuth `state` param (e.g. `openssl rand -hex 32`).
SLACK_STATE_SECRET=
# Public HTTPS origin the app is reachable at (for the manifest request/redirect URLs).
KEPT_PUBLIC_URL=

# --- Server port (App Runner sets this; local default 3000) ---
PORT=3000

# --- Roadmap source for the contradiction check (else Postgres `roadmap` table if DATABASE_URL set) ---
KEPT_ROADMAP_FILE=./roadmap.example.json

# --- Cross-channel RTS via Slack user-token search (set to 1 to enable; needs user-token OAuth) ---
KEPT_SLACK_USER_SEARCH=

# --- Work items via MCP (preferred; satisfies the "MCP server integration" requirement) ---
# Default with NO config below: an in-process SIMULATED MCP server — a real MCP
# client↔server round-trip, no network/OAuth. Precedence: Atlassian/Jira MCP >
# Jira REST > simulated MCP.
#
# Atlassian/Jira hosted Remote MCP server (https://mcp.atlassian.com/v1/mcp):
ATLASSIAN_MCP_TOKEN=
ATLASSIAN_MCP_URL=
JIRA_CLOUD_ID=
JIRA_PROJECT_KEY=
# Override the create-issue tool name if the server's differs from auto-detection:
KEPT_MCP_TOOL=

# --- Legacy direct-API work-item adapter (used only if no MCP token is set above) ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Proof-of-Done sources (W4) — each is REAL when its creds are set, else the collector
#     routes to the in-process SIMULATED MCP proof server, so `npm run demo` + tests stay
#     offline. See docs/INTEGRATIONS.md for exactly where to get each token. ---
#
# GitHub Actions — the always-live proof source (CI run conclusion). No creds → skipped.
GITHUB_TOKEN=
#
# LaunchDarkly — reads a flag's production `on` state → the flag-OFF blocking-negative.
# MCP-preferred (mirrors Jira): set LAUNCHDARKLY_MCP_TOKEN to read the flag over the hosted
# LaunchDarkly MCP server; else it falls back to the LaunchDarkly REST API. The MCP token IS a
# LaunchDarkly API access token (the same value you'd put in LAUNCHDARKLY_API_TOKEN), sent as the
# hosted-MCP `Authorization: Bearer <token>`.
LAUNCHDARKLY_MCP_TOKEN=
# Hosted MCP URL; defaults to https://mcp.launchdarkly.com/mcp/launchdarkly
LAUNCHDARKLY_MCP_URL=
# Override the flag-read MCP tool name if the server's differs (defaults to get-flag):
LAUNCHDARKLY_MCP_FLAG_TOOL=
# REST fallback (used when LAUNCHDARKLY_MCP_TOKEN is unset). Raw `Authorization` (no Bearer):
LAUNCHDARKLY_API_TOKEN=
LAUNCHDARKLY_PROJECT_KEY=
LAUNCHDARKLY_ENVIRONMENT=production
# Optional REST base override (federal / self-hosted); defaults to https://app.launchdarkly.com
LAUNCHDARKLY_BASE_URL=
#
# Jira issue status — hosted Atlassian MCP (ATLASSIAN_MCP_TOKEN/_URL/JIRA_CLOUD_ID above) is
# preferred; else Jira Cloud REST (JIRA_BASE_URL/JIRA_EMAIL/JIRA_API_TOKEN above). Override the
# MCP issue-read tool name if the server's differs from the default:
JIRA_MCP_STATUS_TOOL=
#
# Optional JSON file mapping subject_canonical → { flag, ci } proof targets, so the collector
# knows which flag / CI run corresponds to a subject (the linked Jira issue status target is
# derived automatically from the work item).
KEPT_PROOF_TARGETS_FILE=

# --- Webhook ingestion guard + tenant routing ---
KEPT_WEBHOOK_SECRET=
# Default tenant for webhooks that don't carry an `x-kept-team` header (single-tenant
# dev / the demo driver). In OAuth mode, webhooks with no header/default are routed to
# whichever installed workspace's ledger resolves their refs.
KEPT_TEAM_ID=
# Standalone webhook server port (single-token / Socket Mode dev only; in OAuth HTTP
# mode webhooks are served on PORT alongside /slack/events).
KEPT_WEBHOOK_PORT=3001
