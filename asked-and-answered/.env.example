# Slack app credentials (App A — internal/sandbox install)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# Optional: set to run in Socket Mode (local dev); omit for HTTP mode (deploy)
SLACK_APP_TOKEN=xapp-...

# LLM provider: anthropic | openai | azure
LLM_PROVIDER=azure

# Anthropic (default provider)
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override
# AA_MODEL=claude-haiku-4-5-20251001

# OpenAI / Azure OpenAI
OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_MODEL=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-01

# Storage
AA_DB_PATH=asked-and-answered.db
# Keyed content-hashing for the ledger (REQUIRED — app refuses to start without it)
AA_LEDGER_KEY=change-me-to-a-random-secret

# MCP server (npm run mcp): local single-operator disclosure. Leave unset to
# fail closed (evidence-backed answers redacted). Set to 1 only for a local
# MCP client against your own database.
# AA_MCP_TRUST_LOCAL=1

# HTTP port (deploy)
PORT=3000
